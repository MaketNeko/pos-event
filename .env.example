# Firebase Web config for the online-booth sync layer.
# Copy to `.env` and fill in from Firebase console → Project settings → Your apps.
# These values ship in the client bundle (a Firebase Web apiKey is not a secret);
# secure access via Firestore rules + GCP API-key restrictions, not by hiding them.
VITE_FIREBASE_API_KEY=your-api-key
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=000000000000
VITE_FIREBASE_APP_ID=1:000000000000:web:0000000000000000000000
